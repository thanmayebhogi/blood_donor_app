<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="POST URGENT REQUEST"
        android:textColor="#D32F2F"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/etUrgentBlood"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Required Blood Group (e.g. O+)"
        android:background="@android:drawable/editbox_background_normal"
        android:padding="10dp"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/etHospital"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Hospital Name &amp; City"
        android:background="@android:drawable/editbox_background_normal"
        android:padding="10dp"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/etUrgentPhone"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Contact Number"
        android:inputType="phone"
        android:background="@android:drawable/editbox_background_normal"
        android:padding="10dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnSubmitEmergency"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="POST EMERGENCY NOW"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btnBackFromPost"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="CANCEL"
        android:backgroundTint="#757575"
        android:layout_marginTop="10dp"
        android:textColor="#FFFFFF"/>

</LinearLayout>